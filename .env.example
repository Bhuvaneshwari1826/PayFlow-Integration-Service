# Application
APP_NAME="Takaada Integration Service"
APP_VERSION="1.0.0"
DEBUG=false

# PostgreSQL connection
#
# OPTION A (recommended for local dev) — use the default postgres superuser:
#   Replace YOUR_POSTGRES_PASSWORD with the password you set during PostgreSQL installation.
#   The database was created with: psql -h 127.0.0.1 -U postgres -c "CREATE DATABASE takaada;"
#
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_POSTGRES_PASSWORD@127.0.0.1:5433/takaada
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:YOUR_POSTGRES_PASSWORD@127.0.0.1:5433/takaada
#
# OPTION B — create a dedicated app user first, then use those credentials:
#   psql -h 127.0.0.1 -U postgres -c "CREATE USER takaada WITH PASSWORD 'takaada';"
#   psql -h 127.0.0.1 -U postgres -c "GRANT ALL PRIVILEGES ON DATABASE takaada TO takaada;"
#   Then set:
#     DATABASE_URL=postgresql+asyncpg://takaada:takaada@127.0.0.1:5433/takaada
#     DATABASE_URL_SYNC=postgresql+psycopg2://takaada:takaada@127.0.0.1:5433/takaada
#
# NOTE: Use 127.0.0.1 instead of localhost — on Windows, localhost can resolve
# to IPv6 (::1) which PostgreSQL may not be listening on, causing connection errors.

# External Accounting API
# Point to mock server for local development:  http://localhost:8001
# Swap to real URL in production
EXTERNAL_API_BASE_URL=http://localhost:8001
EXTERNAL_API_KEY=mock-api-key-change-in-prod
EXTERNAL_API_TIMEOUT=30

# Sync scheduler
SYNC_INTERVAL_MINUTES=15
